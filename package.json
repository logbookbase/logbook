{
  "name": "logbook",
  "version": "0.1.0",
  "description": "signed action logs for ai agents",
  "private": true,
  "type": "module",
  "workspaces": ["sdk"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sdk": "npm test --workspace=sdk",
    "build:sdk": "npm run build --workspace=sdk",
    "db:migrate": "tsx scripts/migrate.ts",
    "demo:crypto": "tsx scripts/crypto-demo.ts",
    "demo:register": "tsx scripts/register-demo.ts",
    "demo:events": "tsx scripts/events-demo.ts",
    "demo:sdk": "tsx scripts/sdk-demo.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@scure/base": "^1.1.6",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
