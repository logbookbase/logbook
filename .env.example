# ----- Server -----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ----- Database -----
# Get from neon.tech after creating a project
DATABASE_URL=postgresql://user:pass@host/logbook?sslmode=require

# ----- x402 (enabled in Week 2, leave blank for Week 1) -----
# Project wallet on Base that receives USDC for paid endpoints
X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
# Coinbase CDP facilitator key (from portal.cdp.coinbase.com)
X402_FACILITATOR_URL=https://x402.coinbase.com
X402_FACILITATOR_API_KEY=
# Network: base-mainnet or base-sepolia for testing
X402_NETWORK=base-sepolia

# ----- Pricing (in USDC, base units = 6 decimals) -----
# $0.001 = 1000 base units
PRICE_EVENT_WRITE_USDC=1000
# $0.05 = 50000 base units
PRICE_EVENT_BULK_USDC=50000

# ----- Rate limiting -----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
